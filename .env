APP_NAME=TicketIn
APP_ENV=local
APP_KEY=base64:Y1dUCH51imyfrzmIsDFWuF8EbNdu3c6Te1Yc9XOUvyU=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ticketin_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@ticketin.com
MAIL_FROM_NAME="${APP_NAME}"

# EMAIL CONFIGURATION
# Default local memakai MAIL_MAILER=log agar checkout tidak menunggu koneksi SMTP.
#
# Untuk Mailpit:
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
#
# Untuk Gmail SMTP:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=emailkamu@gmail.com
# MAIL_PASSWORD=app_password_gmail
